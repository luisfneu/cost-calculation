# Copie este arquivo para .env e preencha os valores.
# O .env NÃO é versionado (está no .gitignore).

# Chave de sessão do Flask. Gere uma forte:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave

# Senha-mestre de acesso ao sistema (login). Use algo forte em produção.
APP_SENHA=atelier

# --- Produção (Gunicorn + Cloudflare Tunnel) ---
# Marque como produção: recusa subir se SECRET_KEY/APP_SENHA estiverem fracos.
PRODUCAO=1
# Cookie de sessão só por HTTPS (ligue em produção, atrás do túnel):
SESSION_COOKIE_SECURE=1
# Endereço local que o Gunicorn escuta e o túnel acessa.
BIND=127.0.0.1:8000
THREADS=4
# Quantos backups diários manter (script backup.py):
BACKUP_MANTER=14
# Log em arquivo rotativo (além do stdout). Pasta e nível (padrão instance/logs, INFO):
LOG_DIR=
LOG_LEVEL=info

# Cálculo de frete via Melhor Envio (opcional)
# Token de API gerado na sua conta grátis do Melhor Envio:
MELHOR_ENVIO_TOKEN=
# CEP de origem (do ateliê), só dígitos:
CEP_ORIGEM=

# E-mail transacional via Resend (reset de senha do cliente na vitrine)
# 1) Crie a API key em resend.com  2) Verifique o domínio sabrinahansen.com.br
#    (adicione os registros DNS na Cloudflare) para poder enviar do MAIL_FROM.
RESEND_API_KEY=
# Remetente verificado (ex.: contato@sabrinahansen.com.br). Enquanto o domínio
# não estiver verificado, o Resend só entrega para o e-mail dono da conta.
MAIL_FROM=

# Cópia offsite dos backups (pasta em OUTRO disco / iCloud Drive). Vazio = só local.
# Ex.: BACKUP_OFFSITE_DIR=~/Library/Mobile Documents/com~apple~CloudDocs/backups-atelier
BACKUP_OFFSITE_DIR=/Volumes/EXT_4Tb/BKP_LOJA_SABRINA
