# Copie este arquivo para .env e preencha os valores.
# O .env NÃO é versionado (está no .gitignore).

# Chave de sessão do Flask. Gere uma forte:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave

# Senha-mestre de acesso ao sistema (login). Use algo forte em produção.
APP_SENHA=atelier

# --- Produção (Gunicorn + Cloudflare Tunnel) ---
# Marque como produção: recusa subir se SECRET_KEY/APP_SENHA estiverem fracos.
PRODUCAO=1
# Cookie de sessão só por HTTPS (ligue em produção, atrás do túnel):
SESSION_COOKIE_SECURE=1
# Endereço local que o Gunicorn escuta e o túnel acessa.
BIND=127.0.0.1:8000
THREADS=4
# Quantos backups diários manter (script backup.py):
BACKUP_MANTER=14

# Cálculo de frete via Melhor Envio (opcional)
# Token de API gerado na sua conta grátis do Melhor Envio:
MELHOR_ENVIO_TOKEN=
# CEP de origem (do ateliê), só dígitos:
CEP_ORIGEM=
